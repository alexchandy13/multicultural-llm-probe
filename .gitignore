# Data and weights — never commit
data/*/
!data/*/.gitkeep
models/*/
!models/*/.gitkeep
checkpoints/*/
!checkpoints/*/.gitkeep
# Behavioral results, figures, and the final filtered neuron set ARE versioned —
# small files and useful for paper writing. Large neuron intermediates are not.
outputs/neurons/**/*.pt
outputs/neurons/**/*_max_scores.json
outputs/neurons/**/scores_*.pt
outputs/behavioral/*.json

# CULNIG upstream clone — pulled separately
culnig/_upstream/

# SLURM artifacts
slurm/*.out
slurm/*.err
*.log

# Python
__pycache__/
*.pyc
*.pyo
.pytest_cache/
*.egg-info/
.ipynb_checkpoints/

# Env
.env
.venv/
venv/

# OS
.DS_Store
Thumbs.db
