# Data, weights, checkpoints, outputs — never commit. The whole directories
# are excluded so that on HPC these can safely be symlinks to scratch without
# git seeing them. .gitkeep stubs no longer needed since `data/`,
# `checkpoints/`, and `outputs/` are reconstructed at first run by the
# training/eval/CULNIG scripts themselves.
data/
models/
checkpoints/
outputs/

# CULNIG upstream clone — pulled separately
culnig/_upstream/

# SLURM artifacts
slurm/*.out
slurm/*.err
*.log

# Python
__pycache__/
*.pyc
*.pyo
.pytest_cache/
*.egg-info/
.ipynb_checkpoints/

# Env
.env
.venv/
venv/

# OS
.DS_Store
Thumbs.db
